<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp">

    <Button
        android:id="@+id/btnOpenSettings"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="تفعيل صلاحية الوصول (Accessibility)"
        android:backgroundTint="#FF5722"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="اختر التطبيق المستهدف:"
        android:layout_marginTop="20dp"
        android:textStyle="bold"
        android:textSize="16sp"/>

    <Spinner
        android:id="@+id/spinnerApps"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginTop="10dp"
        android:background="#E0E0E0"/>

    <EditText
        android:id="@+id/etMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="اكتب الرسالة التحذيرية هنا"
        android:layout_marginTop="15dp"/>

    <CheckBox
        android:id="@+id/cbVoice"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="تفعيل الصوت" />

    <CheckBox
        android:id="@+id/cbNotification"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="تفعيل الإشعار المكتوب" />

    <Button
        android:id="@+id/btnSave"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="حفظ الإعدادات"
        android:layout_marginTop="20dp"/>

</LinearLayout>
