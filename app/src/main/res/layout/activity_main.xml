<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp">

    <Button
        android:id="@+id/btnOpenSettings"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="تفعيل صلاحية الوصول (Accessibility)"
        android:backgroundTint="#FF5722"/>

    <EditText
        android:id="@+id/etPackageName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="اسم حزمة التطبيق (مثال: com.whatsapp)"
        android:layout_marginTop="20dp"/>

    <EditText
        android:id="@+id/etMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="الرسالة التحذيرية"
        android:layout_marginTop="10dp"/>

    <CheckBox
        android:id="@+id/cbVoice"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="تفعيل الصوت" />

    <CheckBox
        android:id="@+id/cbNotification"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="تفعيل الإشعار المكتوب" />

    <Button
        android:id="@+id/btnSave"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="حفظ الإعدادات"
        android:layout_marginTop="20dp"/>

</LinearLayout>
