<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:layoutDirection="rtl"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <Button
            android:id="@+id/btnOpenSettings"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="تفعيل صلاحية الوصول (مطلوب)"
            android:textColor="#FFFFFF"
            android:backgroundTint="#FF4500"
            android:layout_marginBottom="15dp"
            android:visibility="gone"/> <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card_dark"
            android:orientation="vertical"
            android:padding="15dp"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="15dp"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="اختر التطبيق المستهدف"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:textSize="16sp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🎯"
                    android:textSize="20sp" />
            </LinearLayout>

            <Spinner
                android:id="@+id/spinnerApps"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:background="@drawable/bg_pill_dark"
                android:popupBackground="#1E293B"
                android:paddingEnd="15dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card_dark"
            android:orientation="vertical"
            android:padding="15dp"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="15dp"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="اكتب الرسالة التحذيرية للإشعار"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:textSize="16sp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💬"
                    android:textSize="20sp" />
            </LinearLayout>

            <EditText
                android:id="@+id/etMessage"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:background="@drawable/bg_pill_dark"
                android:hint="الرسالة التحذيرية..."
                android:textColorHint="#88FFFFFF"
                android:textColor="#FFFFFF"
                android:paddingHorizontal="20dp"
                android:layout_marginBottom="15dp"
                android:textAlignment="center"
                android:textSize="14sp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_pill_dark"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="15dp"
                android:layout_marginBottom="15dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="مدة التكرار (بالثواني) - مثال: 60"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:layout_marginBottom="10dp"/>

                <EditText
                    android:id="@+id/etCooldown"
                    android:layout_width="150dp"
                    android:layout_height="40dp"
                    android:background="@android:color/transparent"
                    android:hint="0000"
                    android:inputType="number"
                    android:textColorHint="#88FFFFFF"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:textAlignment="center"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:background="@drawable/bg_pill_dark"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="20dp"
                android:layout_marginBottom="15dp">
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔔"
                    android:textSize="22sp"/>
                    
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="تفعيل المكتوب كإشعار"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:gravity="center"/>
                    
                <CheckBox
                    android:id="@+id/cbNotification"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:buttonTint="#3B72E5"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:background="@drawable/bg_pill_dark"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="20dp">
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔊"
                    android:textSize="22sp"/>
                    
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="تفعيل التنبيه الصوتي"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:gravity="center"/>
                    
                <CheckBox
                    android:id="@+id/cbVoice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:buttonTint="#3B72E5"/>
            </LinearLayout>
        </LinearLayout>

        <Button
            android:id="@+id/btnPickAudio"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="اختر ملف صوتي من هاتفك"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="16sp"
            android:background="@drawable/bg_btn_blue"
            android:layout_marginBottom="15dp"
            android:elevation="0dp"
            android:stateListAnimator="@null"/>

        <TextView
            android:id="@+id/tvAudioStatus"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:background="@drawable/bg_btn_red_dark"
            android:text="لم يتم اختيار ملف"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:textStyle="bold"
            android:textSize="16sp"
            android:layout_marginBottom="15dp"/>

        <Button
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="حفظ الإعدادات"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="16sp"
            android:background="@drawable/bg_btn_grey"
            android:elevation="0dp"
            android:stateListAnimator="@null"
            android:layout_marginBottom="30dp"/>

    </LinearLayout>
</ScrollView>
